{
  "name": "caiocampos.github.io",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "create-classes": "tsx src/scripts/create-classes.ts",
    "predev": "npm run create-classes",
    "dev": "next dev",
    "dev:full": "NEXT_PUBLIC_FULL_BUILD=true npm run dev",
    "prebuild": "npm run create-classes",
    "build": "next build",
    "build:full": "NEXT_PUBLIC_FULL_BUILD=true npm run build",
    "start": "serve out",
    "lint": "eslint .",
    "prepush": "npm run lint",
    "libretranslate": "docker compose --file libretranslate-docker-compose.yml up -d --build --wait",
    "libretranslate-stop": "docker compose --file libretranslate-docker-compose.yml down",
    "repo-json-builder": "tsx src/scripts/repo-json-builder.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "class-variance-authority": "^0.7",
    "clsx": "^2.1",
    "flag-icons": "^7.5.0",
    "lucide-react": "^1.22.0",
    "next": "16.2",
    "next-themes": "0.4",
    "react": "^19.2",
    "react-dom": "^19.2",
    "recharts": "3.9.1",
    "shadcn": "^4.12.0",
    "tailwind-merge": "^3.6",
    "tailwindcss-animate": "^1.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^26.1",
    "@types/react": "^19.2",
    "@types/react-dom": "^19.2",
    "eslint": "^10.6",
    "eslint-config-next": "^16.2",
    "mini-css-extract-plugin": "^2.10",
    "postcss": "^8.5",
    "tailwindcss": "^4.3.0",
    "ts-node": "^10.9",
    "tsx": "^4.22",
    "typescript": "^6.0"
  }
}
